{
  "name": "@lunch/extension",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "LUNCH_EXTENSION_PROFILE=dev vite build --watch",
    "build": "pnpm run build:internal",
    "build:dev": "node ../../scripts/create-extension-icons.mjs && LUNCH_EXTENSION_PROFILE=dev vite build",
    "build:internal": "node ../../scripts/create-extension-icons.mjs && LUNCH_EXTENSION_PROFILE=internal vite build",
    "test": "LUNCH_EXTENSION_PROFILE=dev vitest run tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lunch/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "vite": "^6.0.7"
  }
}
