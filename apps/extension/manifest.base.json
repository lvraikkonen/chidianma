{
  "manifest_version": 3,
  "name": "中午吃点啥",
  "version": "0.2.0",
  "description": "为小团队提供 2–3 个有理由的午饭选择和适度提醒。",
  "permissions": ["alarms", "notifications", "storage"],
  "action": {
    "default_title": "中午吃点啥",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
